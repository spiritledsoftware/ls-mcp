{
  "name": "language-server-mcp",
  "version": "0.3.1",
  "description": "MCP server exposing Language Server Protocol capabilities over stdio.",
  "keywords": [
    "language-server",
    "language-server-protocol",
    "lsp",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/spiritledsoftware/language-server-mcp#readme",
  "bugs": {
    "url": "https://github.com/spiritledsoftware/language-server-mcp/issues"
  },
  "license": "MIT",
  "author": "Ian Pascoe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spiritledsoftware/language-server-mcp.git"
  },
  "bin": {
    "language-server-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs/architecture.md",
    "docs/config.md",
    "docs/tools.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsgo -p tsconfig.build.json && rolldown -c && chmod +x dist/index.js",
    "build:watch": "rm -rf dist && rolldown -c --watch",
    "dev": "tsx src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "generate:lsp-output-schemas": "node scripts/generate-lsp-output-schemas.mjs",
    "check:lsp-output-schemas": "pnpm run generate:lsp-output-schemas && git diff --exit-code -- src/tools/generated && test -z \"$(git ls-files --others --exclude-standard -- src/tools/generated)\"",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsonc-parser": "^3.3.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-uri": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260524.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown": "^1.0.2",
    "ts-to-zod": "^5.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vscode-languageserver-types": "3.17.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.2.2"
}
